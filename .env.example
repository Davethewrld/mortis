# ─── Deployment ──────────────────────────────────────────────────────
# Your Alchemy or Infura Sepolia RPC endpoint
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Private key of the vault owner (deployer). DO NOT commit this.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Address that inherits if the dead man's switch fires
BENEFICIARY=0xBENEFICIARY_ADDRESS_HERE

# Trigger window in days (default 180)
TRIGGER_DAYS=180

# Optional: ETH to deposit at deploy time (e.g. "0.1")
INITIAL_DEPOSIT_ETH=0

# ─── Verification ─────────────────────────────────────────────────────
# Get this from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY_HERE
